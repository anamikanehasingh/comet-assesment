# Application
# local | development | staging | production
APP_ENV=local

# PostgreSQL — use docker-compose defaults locally
# Secrets: NEVER commit real credentials; use vault/secret manager in non-local environments.
DATABASE_URL=postgresql+asyncpg://comet:comet@localhost:5432/comet

# Redis
# Secrets: protect Redis AUTH in production.
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Compose-only: override published host port mapping (defaults to 8000)
# COMPOSE_API_PUBLISH_PORT=8001

# Rate limiting (SlowAPI — uses Redis when enabled, else in-memory)
RATE_LIMIT_ENABLED=false

# JWT (HS256) — required outside local; rotate in staging/production
JWT_SECRET_KEY=dev-insecure-comet-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery (defaults to REDIS_URL when unset)
# CELERY_BROKER_URL=redis://localhost:6379/0

MATCHING_OFFER_TTL_SECONDS=60
DRIVER_LOCATION_DB_THROTTLE_SECONDS=30

# New Relic (optional) — set only in environments where you want APM
# Secrets: NEW_RELIC_LICENSE_KEY is highly sensitive; inject via CI/provider, not committed files.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=comet-api-local
NEW_RELIC_LOG=stdout
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Testing (optional overrides for pytest / CI)
# DATABASE_URL=postgresql+asyncpg://comet:comet@localhost:5432/comet_test
# REDIS_URL=redis://localhost:6379/15
